# Copy this file to .env and fill in real values.

# Required — primary LLM
GEMINI_API_KEY=

# Required — fallback LLM (used if Gemini fails/rate-limits). You can supply
# just GROQ_API_KEY_1 and leave the rest blank; fallback_llm.py rotates
# through whichever of these are set.
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=

# Optional but strongly recommended — without this, GitHub REST calls are
# rate-limited to 60/hour instead of 5000/hour.
GITHUB_TOKEN=

# Optional — restrict CORS in production. Leave unset ("*") for local dev.
# CORS_ALLOW_ORIGINS=https://your-frontend-domain.com
